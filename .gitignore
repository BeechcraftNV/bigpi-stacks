# 1. Ignore everything by default
*

# 2. Allow root-level configuration and documentation
!.gitignore
!README.md
!GEMINI.md
!.env.example

# 3. Allow only specific files in the compose directory
!compose/
!compose/*.yml
!compose/*.yaml
!compose/README.md

# 4. Explicitly ignore sensitive or generated files (even if they match above)
.env
configs/**
.DS_Store
*.log
*.backup
*.tmp
